# Telegram
BOT_TOKEN=your_telegram_bot_token

# Yandex Cloud — Alice AI LLM
# Получить: https://console.yandex.cloud/ → AI Studio → API-ключ + ID каталога
YANDEX_API_KEY=your_yandex_api_key
YANDEX_FOLDER_ID=your_folder_id
YANDEX_MODEL=aliceai-llm

# Погода (OpenWeatherMap — бесплатный tier)
OPENWEATHER_API_KEY=your_openweather_api_key

# База данных (SQLite по умолчанию)
DATABASE_URL=sqlite+aiosqlite:///./data/wardrobe.db

# Папка для изображений гардероба
STORAGE_PATH=./data/wardrobe_images
